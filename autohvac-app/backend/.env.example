# AutoHVAC Backend Environment Variables

# Server Configuration
PORT=8000
DEBUG=false

# CORS Origins (comma separated)
ALLOWED_ORIGINS=http://localhost:3000,https://autohvac.vercel.app

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
LOG_JSON_FORMAT=true

# Database Configuration
DATABASE_URL=sqlite:///./autohvac.db
CLIMATE_DB_PATH=zip_climate_database.db

# Cache Configuration
CACHE_TTL_HOURS=168  # 7 days (climate data cache)
CACHE_MAX_SIZE=10000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=2000

# File Storage
UPLOAD_MAX_SIZE=50MB
MAX_FILE_SIZE_MB=10  # Individual file limit
STORAGE_PATH=/app/uploads

# Performance Monitoring
ENABLE_PERFORMANCE_LOGGING=true
SLOW_QUERY_THRESHOLD_MS=100

# ML Model Configuration
MODEL_PATH=/app/ml_models/trained_models/
ROOM_DETECTION_CONFIDENCE=0.85

# API Keys (required for AI features)
OPENAI_API_KEY=your_openai_api_key_here
# API_KEY_CLIMATE_DATA=your_api_key_here

# Production Settings (uncomment for production)
# LOG_LEVEL=WARNING
# DEBUG=false
# LOG_JSON_FORMAT=true
# CORS_ALLOW_CREDENTIALS=true