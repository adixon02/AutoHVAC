1{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/blueprint/:path*",
      "destination": "https://your-backend-url.railway.app/api/blueprint/:path*"
    },
    {
      "source": "/api/calculations/:path*",
      "destination": "https://your-backend-url.railway.app/api/calculations/:path*"
    },
    {
      "source": "/api/export/:path*",
      "destination": "https://your-backend-url.railway.app/api/export/:path*"
    }
  ]
}